# PaperClue backend configuration — copy to .env and fill in.

# Required for insight/review/format/browse synthesis (Claude generation).
ANTHROPIC_API_KEY=

# Required for lazy semantic indexing (chat and similarity retrieval).
OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=384


# Optional: raises Semantic Scholar rate limits. Works without a key at demo scale.
S2_API_KEY=

# Claude models
CLAUDE_MODEL_FAST=claude-sonnet-4-5
CLAUDE_MODEL_SMART=claude-sonnet-4-5

# Demo tenant (university corpus isolation)
TENANT_ID=demo-university

# Supabase (auth). Project Settings -> API in the Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY is backend-only, never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: secure source database connection for external data sources
# Supported types: postgres, mysql, sqlite, mssql
SOURCE_DATABASE_TYPE=postgres
SOURCE_DATABASE_URL=
SOURCE_DATABASE_HOST=
SOURCE_DATABASE_PORT=5432
SOURCE_DATABASE_NAME=
SOURCE_DATABASE_USER=
SOURCE_DATABASE_PASSWORD=
SOURCE_DATABASE_SSL_MODE=prefer
SOURCE_DATABASE_SSL_CA=
SOURCE_DATABASE_SSL_CERT=
SOURCE_DATABASE_SSL_KEY=
SOURCE_DATABASE_TRUST_SERVER_CERTIFICATE=false

# Encrypts saved Data Source Connection secrets at rest (Fernet). Falls back to
# SUPABASE_SERVICE_ROLE_KEY if unset — set this explicitly in production.
CONNECTION_ENCRYPTION_KEY=

# Supabase (auth + database)
DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
